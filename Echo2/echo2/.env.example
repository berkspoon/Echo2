# Application
DEBUG=true
SECRET_KEY=change-me-in-production

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Microsoft Entra ID (SSO) — optional until IT wires up app registration
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=http://localhost:8000/auth/callback

# App URL
BASE_URL=http://localhost:8000

# Tester gate — set to a shared password to require HTTP Basic Auth on every
# request. Leave empty for local dev (no gate). Set on Railway to lock the
# hosted URL to invited testers only.
TESTER_PASSWORD=
